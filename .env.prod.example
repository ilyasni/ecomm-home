# ---- Strapi database (managed PostgreSQL in Coolify) ----
DATABASE_HOST={{postgres_host}}
DATABASE_PORT=5432
DATABASE_NAME={{postgres_db}}
DATABASE_USERNAME={{postgres_user}}
DATABASE_PASSWORD={{postgres_password}}

# ---- Redis (managed Redis in Coolify, optional for Strapi plugins) ----
REDIS_HOST={{redis_host}}
REDIS_PORT=6379
REDIS_PASSWORD={{redis_password}}

# ---- Strapi secrets ----
STRAPI_APP_KEYS={{comma_separated_4_keys}}
STRAPI_API_TOKEN_SALT={{secret}}
STRAPI_ADMIN_JWT_SECRET={{secret}}
STRAPI_TRANSFER_TOKEN_SALT={{secret}}
STRAPI_JWT_SECRET={{secret}}
STRAPI_ADMIN_ENCRYPTION_KEY={{secret}}
STRAPI_ADMIN_SESSION_MAX_LIFESPAN=86400
STRAPI_ADMIN_REFRESH_TOKEN_MAX_LIFESPAN=2592000

# ---- Storefront runtime ----
NEXT_PUBLIC_STRAPI_URL=https://cms.example.com
NEXT_PUBLIC_STRAPI_MEDIA_URL=https://cms.example.com
STRAPI_MEDIA_HOSTNAME=cms.example.com
STRAPI_API_TOKEN={{strapi_read_token}}
