    },
    "advantageImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "partnershipFormTitle": {
      "type": "string"
    },
    "partnershipFormSubtitle": {
      "type": "text"
    },
    "partnershipFormImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
