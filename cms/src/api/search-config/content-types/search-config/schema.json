{
  "kind": "singleType",
  "collectionName": "search_configs",
  "info": {
    "singularName": "search-config",
    "pluralName": "search-configs",
    "displayName": "Search Config",
    "description": "Конфигурация поиска — популярные запросы и рекомендуемые товары"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "popularQueries": {
      "type": "component",
      "repeatable": true,
      "component": "search.popular-query"
    },
    "featuredProducts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
