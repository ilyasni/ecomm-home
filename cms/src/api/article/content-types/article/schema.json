{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Статья / Новость"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["новости", "идеи", "новинки", "ткани"],
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "toc": {
      "type": "component",
      "repeatable": true,
      "component": "article.toc-item"
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "article.section-heading",
        "article.section-text",
        "article.section-list",
        "article.section-images",
        "article.section-table"
      ]
    },
    "recommendedProducts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    }
  }
}
