{
  "kind": "collectionType",
  "collectionName": "collections",
  "info": {
    "singularName": "collection",
    "pluralName": "collections",
    "displayName": "Collection",
    "description": "Коллекция товаров"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "heroTitle": {
      "type": "string"
    },
    "heroSubtitle": {
      "type": "text"
    },
    "heroImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "descriptionTitle": {
      "type": "string"
    },
    "descriptionParagraphs": {
      "type": "json"
    },
    "mediaImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "mediaVideo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "videos"]
    },
    "bannerTitle": {
      "type": "string"
    },
    "bannerDescription": {
      "type": "text"
    },
    "bannerButtonLabel": {
      "type": "string"
    },
    "bannerImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "price": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "mappedBy": "collections"
    }
  }
}
