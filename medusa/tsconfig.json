{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "lib": ["ES2019"],
    "allowJs": true,
    "strict": false,
    "outDir": ".medusa/server",
    "rootDir": ".",
    "skipLibCheck": true,
    "declaration": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "paths": {}
  },
  "include": ["src", "medusa-config.ts"],
  "exclude": ["node_modules", ".medusa"]
}
