# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD={{secret}}

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ──────────────────────────────────────────────
# Strapi CMS
# ──────────────────────────────────────────────
STRAPI_HOST=0.0.0.0
STRAPI_PORT=1337
STRAPI_APP_KEYS={{secret}},{{secret}},{{secret}},{{secret}}
STRAPI_API_TOKEN_SALT={{secret}}
STRAPI_ADMIN_JWT_SECRET={{secret}}
ADMIN_ENCRYPTION_KEY={{secret}}
ADMIN_REFRESH_TOKEN_MAX_LIFESPAN=30d
ADMIN_SESSION_MAX_LIFESPAN=30d
STRAPI_TRANSFER_TOKEN_SALT={{secret}}
STRAPI_JWT_SECRET={{secret}}

# ──────────────────────────────────────────────
# Next.js Frontend
# ──────────────────────────────────────────────
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_MEDIA_URL=http://localhost:1337
STRAPI_INTERNAL_URL=http://cms:1337
STRAPI_API_TOKEN={{secret}}
STRAPI_MEDIA_HOSTNAME=localhost

# ──────────────────────────────────────────────
# Medusa Commerce
# ──────────────────────────────────────────────
MEDUSA_POSTGRES_DB=medusa
MEDUSA_POSTGRES_USER=medusa
MEDUSA_POSTGRES_PASSWORD={{secret}}
MEDUSA_JWT_SECRET={{secret}}
MEDUSA_COOKIE_SECRET={{secret}}
MEDUSA_PUBLISHABLE_KEY={{medusa-publishable-key}}
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD={{secret}}
MEDUSA_STORE_CORS=http://localhost:3000
MEDUSA_ADMIN_CORS=http://localhost:3000
MEDUSA_AUTH_CORS=http://localhost:3000

# ──────────────────────────────────────────────
# MinIO (S3-compatible object storage)
# ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD={{secret-min-8-chars}}
MINIO_BUCKET=strapi-uploads

# ──────────────────────────────────────────────
# Imgproxy (image processing)
# hex: openssl rand -hex 32
# ──────────────────────────────────────────────
IMGPROXY_KEY={{hex-32-bytes}}
IMGPROXY_SALT={{hex-32-bytes}}
# Dev: public URL for browser (localhost). Prod: CDN hostname.
# NEXT_PUBLIC_IMGPROXY_URL=http://localhost:8080
# Production only (Next.js remotePatterns + public URL):
# IMGPROXY_HOSTNAME=media.produmantech.ru
# NEXT_PUBLIC_IMGPROXY_URL=https://media.produmantech.ru

# ──────────────────────────────────────────────
# Meilisearch
# ──────────────────────────────────────────────
MEILI_MASTER_KEY={{secret}}
REINDEX_SECRET={{secret}}

# ──────────────────────────────────────────────
# Payment / Delivery (optional — stub mode if empty)
# ──────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
CDEK_FROM_CITY_CODE=44

# ──────────────────────────────────────────────
# Email / SMTP (Phase 5)
# Graceful: если не настроен — письма не отправляются, ошибок нет.
# Пример для Яндекс 360: SMTP_HOST=smtp.yandex.ru SMTP_PORT=465 SMTP_SECURE=true
# Пример для Gmail:      SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_SECURE=false
# ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Vita Brava Home <noreply@vitabrava.ru>
EMAIL_ADMIN=
